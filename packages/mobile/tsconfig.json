{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@hiperhealth/hphvision-lib": ["packages/mobile-lib/src"],
      "@hiperhealth/hphvision-lib/*": ["packages/mobile-lib/src/*"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "../../packages/mobile-lib/src/**/*.ts",
    "../../packages/mobile-lib/src/**/*.tsx"
  ]
}
